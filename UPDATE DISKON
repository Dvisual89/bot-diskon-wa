// FUNGSI 1: Ambil Plafon Diskon dari Excel
function getMaxDiskon(namaBarang) {
    try {
        const path = require('path');
        const fs = require('fs');
        const filePath = path.resolve(__dirname, 'database.xlsx');
        const fileBuffer = fs.readFileSync(filePath);
        const workbook = XLSX.read(fileBuffer, { type: 'buffer' });
        
        // Membersihkan input: hapus spasi ganda, titik, dan ubah ke lowercase
        const namaCari = namaBarang.toLowerCase().replace(/[^a-z0-9]/g, '');
        const daftarSheet = ["DISKON 2026", "DISKON 2025"];
        let maxDiskonFound = 0;

        for (const namaSheet of daftarSheet) {
            const sh = workbook.Sheets[namaSheet];
            if (!sh) continue;

            // Ambil data dalam bentuk array of arrays (header: 1)
            const data = XLSX.utils.sheet_to_json(sh, { header: 1 });

            for (let row of data) {
                // Bersihkan data di kolom A Excel dari karakter non-alfanumerik
                let deskripsiDiExcel = String(row[0] || "").toLowerCase().trim();
                if (!deskripsiDiExcel) continue;

                const deskripsiClean = deskripsiDiExcel.replace(/[^a-z0-9]/g, '');

                // Cek kecocokan (Partial Match)
                // Contoh: "dn068" ada di dalam "dn068bg2led20..."
                if (namaCari.includes(deskripsiClean) || deskripsiClean.includes(namaCari)) {
                    let nilai = parseFloat(row[1]);
                    if (!isNaN(nilai)) {
                        // Handle jika user nulis 0.35 di excel (maksudnya 35%)
                        if (nilai < 1 && nilai > 0) nilai = nilai * 100; 

                        // --- FIX PEMBULATAN DI SINI ---
                        // Menggunakan Math.round agar 56.5999... jadi 56.6
                        nilai = Math.round(nilai * 10) / 10; 
                        
                        if (nilai > maxDiskonFound) maxDiskonFound = nilai;
                    }
                }
            }
            // Jika sudah ketemu di sheet 2026 (terbaru), langsung break
            if (maxDiskonFound > 0) break; 
        }
        return maxDiskonFound;
    } catch (e) {
        console.log("❌ Error getMaxDiskon:", e.message);
        return 0;
    }
}

function cariDiExcel(namaInput, khususStok = false, minStok = 0) {
    try {
        const path = require('path');
        const fs = require('fs');
        const filePath = path.resolve(__dirname, 'database.xlsx');
        
        const fileBuffer = fs.readFileSync(filePath);
        const workbook = XLSX.read(fileBuffer, { type: 'buffer' });
        
        const inputClean = namaInput.toLowerCase().trim();
        const keywords = inputClean.split(/[\s,]+/).filter(k => k.length > 0);
        
        let hasilPencarian = [];
        const semuaSheet = workbook.SheetNames;
        const sheetStok = ["FREE STOCK MTO", "FREE STOCK MTS", "STOCK 2026"];
        
        let mapStok = new Map();

        sheetStok.forEach(sName => {
            const sh = workbook.Sheets[sName];
            if (!sh) return;
            const data = XLSX.utils.sheet_to_json(sh, { header: 1, raw: true });
            
            data.forEach(row => {
                const nama = String(row[0] || "").replace(/\s+/g, ' ').trim();
                if (!nama) return;

                let qtyRaw;
                if (sName === "STOCK 2026") {
                    qtyRaw = row[6]; 
                } else {
                    qtyRaw = row[1]; 
                }

                let qty = 0;
                if (typeof qtyRaw === 'number') {
                    qty = qtyRaw;
                } else {
                    qty = parseInt(String(qtyRaw || "0").replace(/[^0-9]/g, '')) || 0;
                }
                
                if (!mapStok.has(nama)) {
                    mapStok.set(nama, { mto: 0, mts: 0, s2026: 0 });
                }
                const current = mapStok.get(nama);
                if (sName === "FREE STOCK MTO") current.mto += qty;
                if (sName === "FREE STOCK MTS") current.mts += qty;
                if (sName === "STOCK 2026") current.s2026 += qty;
            });
        });

        // Daftar sheet yang harus diabaikan (Stok dan Diskon)
const sheetDilarang = [...sheetStok, "DISKON 2025", "DISKON 2026"];

// Filter agar hanya mencari di sheet Produk/Price List
const listSheetTarget = semuaSheet.filter(s => !sheetDilarang.includes(s));

for (const sheetName of listSheetTarget) {
    const sheet = workbook.Sheets[sheetName];
    // Gunakan raw: true agar angka tidak terformat otomatis oleh XLSX
    const rows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: "", raw: true });

    for (let row of rows) {
        const rawCol0 = row[0];
        const rawCol1 = row[1]; // Kolom Harga
        
        const val0 = String(rawCol0 || "").replace(/\s+/g, ' ').trim();
        
        // Skip jika baris kosong atau header
        if (!val0 || val0.toLowerCase() === 'description' || val0.toLowerCase() === 'nama barang') continue;

        const desc0 = val0.toLowerCase();
        const isMatchNama = keywords.every(k => desc0.includes(k));

        if (isMatchNama) {
            const dataStok = mapStok.get(val0) || { mto: 0, mts: 0, s2026: 0 };
            const totalStok = dataStok.mto + dataStok.mts + dataStok.s2026;

            if (totalStok >= minStok) {
                let hargaFinal = 0;
                
                // Cek apakah rawCol1 memang angka
                if (typeof rawCol1 === 'number') {
                    hargaFinal = rawCol1;
                } else {
                    // Jika string (misal: "150.000"), bersihkan karakter non-angka
                    const cleanHarga = String(rawCol1 || "0").replace(/[^0-9]/g, '');
                    hargaFinal = parseInt(cleanHarga) || 0;
                }

                // VALIDASI: Harga harus lebih dari 100 (asumsi tidak ada barang seharga < Rp 100)
                // Ini untuk mencegah diskon (0.35) atau baris sampah masuk
                if (hargaFinal > 100) {
                    hasilPencarian.push({
                        Nama: val0,
                        Harga: hargaFinal,
                        Leadtime: String(row[2] || "-"),
                        Status: String(row[3] || ""),
                        StokMTO: dataStok.mto,
                        StokMTS: dataStok.mts,
                        Stok2026: dataStok.s2026,
                        TotalStok: totalStok
                    });
                }
            }
        }
    }
}
        
        const exact = hasilPencarian.find(b => b.Nama.toLowerCase().trim() === inputClean);
        return exact ? [exact] : hasilPencarian;

    } catch (error) {
        console.log('❌ Error Deep Reading:', error.message);
        return [];
    }
}

