const { Client, LocalAuth } = require('whatsapp-web.js');
const qrcode = require('qrcode-terminal');
const XLSX = require('xlsx');

const client = new Client({
    authStrategy: new LocalAuth(),
    puppeteer: { args: ['--no-sandbox', '--disable-setuid-sandbox'] }
});

/**
 * TAHAP 1: Fungsi Pencarian (Optimasi untuk Nama Barang Panjang & Karakter Khusus)
 */
function cariDiExcel(namaInput, khususStok = false) {
    try {
        const workbook = XLSX.readFile('./database.xlsx');
        const keywords = namaInput.toLowerCase().replace(/\u00A0/g, ' ').split(/[\s,]+/).filter(k => k.length > 0);

        let dataProduk = null;

        // Tentukan daftar sheet yang akan dicari berdasarkan kebutuhan
        let listSheetTarget;
        if (khususStok) {
            // Jika dipanggil oleh 'cek stock', hanya cari di sheet stok
            listSheetTarget = ["FREE STOCK MTO", "FREE STOCK MTS", "STOCK 2026"];
        } else {
            // Jika 'cek harga/all', cari di sheet pricelist (kecuali sheet stok)
            const semuaSheet = workbook.SheetNames;
            const listSheetStok = ["FREE STOCK MTO", "FREE STOCK MTS", "STOCK 2026"];
            listSheetTarget = semuaSheet.filter(s => !listSheetStok.includes(s));
        }

        for (const sheetName of listSheetTarget) {
            const sheet = workbook.Sheets[sheetName];
            if (!sheet) continue;
            const rows = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: "" });

            for (let row of rows) {
                // Cek kolom 0 atau 1 (karena letak nama barang bisa berbeda tiap sheet)
                const desc0 = String(row[0] || "").toLowerCase();
                const desc1 = String(row[1] || "").toLowerCase();
                
                const isMatch = keywords.every(k => desc0.includes(k) || desc1.includes(k));

                if (isMatch) {
                    const namaFix = desc1.length > desc0.length ? row[1] : row[0];
                    
                    dataProduk = {
                        Nama: namaFix,
                        Harga: typeof row[1] === 'number' ? row[1] : parseFloat(String(row[1] || 0).replace(/[^0-9]/g, '')),
                        Leadtime: row[2] || '-',
                        Status: row[3] ? String(row[3]) : '',
                        StokMTO: 0, StokMTS: 0, Stok2026: 0
                    };
                    break; 
                }
            }
            if (dataProduk) break;
        }

        // TAHAP AMBIL STOK (Selalu ambil dari 3 sheet utama ini)
        if (dataProduk) {
            const namaBarang = dataProduk.Nama.toLowerCase().trim();
            const ambilData = (namaSheet, indexKolom) => {
                const s = workbook.Sheets[namaSheet];
                if (!s) return 0;
                const rws = XLSX.utils.sheet_to_json(s, { header: 1, defval: "" });
                const match = rws.find(r => 
                    (r[0] && String(r[0]).toLowerCase().trim() === namaBarang) ||
                    (r[1] && String(r[1]).toLowerCase().trim() === namaBarang)
                );
                return match ? (typeof match[indexKolom] === 'number' ? match[indexKolom] : parseInt(match[indexKolom]) || 0) : 0;
            };

            dataProduk.StokMTO = ambilData("FREE STOCK MTO", 1);
            dataProduk.StokMTS = ambilData("FREE STOCK MTS", 1);
            dataProduk.Stok2026 = ambilData("STOCK 2026", 6);
        }

        return dataProduk;
    } catch (error) {
        console.log('❌ Error:', error.message);
        return null;
    }
}

client.on('qr', qr => qrcode.generate(qr, { small: true }));

client.on('ready', () => {
    console.log('✅ Bot Philips Online!');
});

client.on('message_create', async msg => {
    // 1. Ambil isi pesan dan ID Chat
    const isiPesan = msg.body.toLowerCase().trim();
    const chatID = msg.fromMe ? msg.to : msg.from;

    // 2. LOGIKA PENGAMAN:
    // Menambahkan '/' ke dalam daftar kata kunci agar fromMe tetap bisa akses
    if (msg.fromMe) {
        const kataKunci = ['cek ', 'menu', '/'];
        const apakahPerintah = kataKunci.some(k => isiPesan.startsWith(k));
        if (!apakahPerintah) return;
    }

    // --- FITUR SLASH COMMAND (MODERN MENU) ---
    // Jika user hanya mengetik "/" atau "/menu" atau "menu"
    if (isiPesan === '/' || isiPesan === '/menu' || isiPesan === 'menu') {
        const menuTeks = `🤖 *PHILIPS PRICE BOT*
──────────────────
Silakan pilih menu:

1️⃣ *CEK HARGA (Pricelist)*
Format: *cek harga [nama barang]*

2️⃣ *HITUNG DISKON (Rincian)*
Format: *cek diskon [nama barang] [diskon]*

3️⃣ *CEK STOCK TPP (Rinci)*
Format: *cek stock [nama]*

4️⃣ *FORMAT PENAWARAN (Ready Copy)*
Format: *cek all [nama] [diskon]*
Contoh: _cek all BVP171 30%_
──────────────────`;
        return await client.sendMessage(chatID, menuTeks);
    }

    // --- FITUR 4: CEK ALL ---
    if (isiPesan.startsWith('cek all ')) {
        const matchFormat = msg.body.match(/cek all (.+) (\d+%|\d+)$/i);
        if (matchFormat) {
            const namaCari = matchFormat[1].trim(); 
            const diskonStr = matchFormat[2]; 
            const persen = parseFloat(diskonStr.replace('%', ''));
            const barang = cariDiExcel(namaCari);

            if (barang) {
                const pot = (persen / 100) * barang.Harga;
                const nettOriginal = barang.Harga - pot;
                const nettBulat = Math.ceil(nettOriginal / 50) * 50; 
                const formatRp = (n) => n.toLocaleString('id-ID');
                const totalStok = (barang.StokMTO || 0) + (barang.StokMTS || 0) + (barang.Stok2026 || 0);
                const statusStok = totalStok > 0 ? `Ready Stock (${totalStok} unit)` : "Indent";

                const reply = `*${barang.Nama}* harga nett *Rp ${formatRp(nettBulat)} / exc PPN*, Franco Semarang, TPP ${statusStok}.`;
                return await client.sendMessage(chatID, reply, { quotedMessageId: msg.id._serialized });
            } else {
                return await client.sendMessage(chatID, `❌ Barang "${namaCari}" tidak ditemukan atau sudah Phase Out.`);
            }
        } else {
            return await client.sendMessage(chatID, "❌ Format salah. Contoh: *cek all BVP171 30%*");
        }
    }

    // --- LOGIKA PERINTAH STOCK ---
    if (isiPesan.startsWith('cek stock ')) {
        const namaCari = msg.body.substring(10).trim();
        
        // CUKUP TAMBAHKAN PARAMETER true DI SINI
        const barang = cariDiExcel(namaCari, true); 
        
        if (barang) {
            const totalStok = barang.StokMTO + barang.StokMTS + barang.Stok2026;
            const reply = `📦 *LAPORAN STOK TERPADU*
──────────────────
🔍 *Produk:* ${barang.Nama}

📊 *Rincian Stok:*
• FREE STOCK MTO : *${barang.StokMTO}*
• FREE STOCK MTS : *${barang.StokMTS}*
• STOCK 2026     : *${barang.Stok2026}*

📈 *TOTAL STOCK : ${totalStok} unit*
🕒 *Leadtime:* ${barang.Leadtime}
──────────────────
_Data real-time dari sistem database._`;
            return await client.sendMessage(chatID, reply, { quotedMessageId: msg.id._serialized });
        } else {
            return await client.sendMessage(chatID, `❌ Data stok untuk "${namaCari}" tidak ditemukan.`);
        }
    }

    // --- FITUR 1: CEK HARGA ---
    if (isiPesan.startsWith('cek harga ')) {
        const namaCari = msg.body.substring(10).trim();
        const barang = cariDiExcel(namaCari);
        if (barang) {
            const formatRp = (n) => "Rp " + Math.round(n).toLocaleString('id-ID');
            let labelStatus = barang.Status.toLowerCase().includes("phase") ? "\n⚠️ *STATUS: PHASE OUT*" : "";
            const reply = `🔍 *DATA PRICELIST*
──────────────────
📦 *Produk:* ${barang.Nama}
💰 *Price List:* *${formatRp(barang.Harga)}*
🕒 *Leadtime:* ${barang.Leadtime} ${labelStatus}
──────────────────
_Ketik "cek diskon [nama] [diskon]" untuk hitung nett._`;
            return await client.sendMessage(chatID, reply, { quotedMessageId: msg.id._serialized });
        } else {
            return await client.sendMessage(chatID, `❌ Barang "${namaCari}" tidak ditemukan.`);
        }
    }

    // --- FITUR 2: CEK DISKON ---
    if (isiPesan.startsWith('cek diskon ')) {
        const match = msg.body.match(/cek diskon (.+) (\d+%|\d+)$/i);
        if (match) {
            const namaCari = match[1].trim();
            const persen = parseFloat(match[2].replace('%', ''));
            const barang = cariDiExcel(namaCari);
            if (barang) {
                const pot = (persen / 100) * barang.Harga;
                const nettOriginal = barang.Harga - pot;
                const nettBulat = Math.ceil(nettOriginal / 50) * 50;
                const formatRp = (n) => "Rp " + Math.round(n).toLocaleString('id-ID');
                let labelStatus = barang.Status.toLowerCase().includes("phase") ? "\n⚠️ *STATUS: PHASE OUT*" : "";
                const reply = `🔍 *HASIL HITUNG DISKON*
──────────────────
📦 *Produk:* ${barang.Nama}
💰 *Price List:* ${formatRp(barang.Harga)}
🏷️ *Diskon:* ${persen}%
🕒 *Leadtime:* ${barang.Leadtime} ${labelStatus}
──────────────────
💵 *HARGA NETT:* ${formatRp(nettOriginal)}
⚖️ *PEMBULATAN:* *${formatRp(nettBulat)}*`;
                return await client.sendMessage(chatID, reply, { quotedMessageId: msg.id._serialized });
            } else {
                return await client.sendMessage(chatID, `❌ Barang "${namaCari}" tidak ditemukan.`);
            }
        }
    }
});

client.initialize();
