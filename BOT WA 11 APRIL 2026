function loadWorkbook() {
    const now = Date.now();

    if (!cachedWorkbook || now - lastLoadTime > 300000) {
        const filePath = path.resolve(__dirname, 'database.xlsx');
        const fileBuffer = fs.readFileSync(filePath);
        cachedWorkbook = XLSX.read(fileBuffer, { type: 'buffer' });
        buildIndex(); // 🔥 WAJIB
        lastLoadTime = now;
        console.log('♻️ Reload Excel...');
    }

    return cachedWorkbook;
}

// FUNGSI 1: Ambil Plafon Diskon dari Excel
function getMaxDiskon(namaBarang) {
    try {
        const workbook = loadWorkbook();
        
        const namaCari = namaBarang.toLowerCase().replace(/[^a-z0-9]/g, '');
        const daftarSheet = ["DISKON 2026", "DISKON 2025"];
        let maxDiskonFound = 0;

        for (const namaSheet of daftarSheet) {
            const sh = workbook.Sheets[namaSheet];
            if (!sh) continue;

            const data = XLSX.utils.sheet_to_json(sh, { header: 1 });

            for (let row of data) {
                let deskripsiExcelRaw = String(row[0] || "").trim();
                if (!deskripsiExcelRaw || deskripsiExcelRaw.toLowerCase() === 'description') continue;

                const deskripsiExcelClean = deskripsiExcelRaw.toLowerCase().replace(/[^a-z0-9]/g, '');

                if (namaCari.includes(deskripsiExcelClean) || deskripsiExcelClean.includes(namaCari)) {
                    let nilai = parseFloat(row[1]);
                    if (!isNaN(nilai)) {
                        if (nilai < 1 && nilai > 0) nilai = nilai * 100; 
                        nilai = Math.round(nilai * 10) / 10; 
                        if (nilai > maxDiskonFound) maxDiskonFound = nilai;
                    }
                }
            }
            if (maxDiskonFound > 0) break; 
        }
        return maxDiskonFound;
    } catch (e) {
        console.log("❌ Error getMaxDiskon:", e.message);
        return 0;
    }
}

function normalizeNama(text) {
    return String(text || "")
        .toLowerCase()
        .replace(/[^a-z0-9]/g, '');
}

let indexBarang = [];
let indexStok = new Map();
let fuse = null; // 🔥 TAMBAHAN

function cariDiExcel(namaInput, khususStok = false, minStok = 0) {
    try {
        const inputClean = namaInput.toLowerCase().trim();
        const keywords = inputClean.split(/[\s,]+/).filter(k => k.length > 0);

        let hasil = [];

        // 🔥 STEP 1: EXACT SEARCH (cara lama kamu)
        hasil = indexBarang.filter(b => {
            const cocok = keywords.every(k => b.Nama.toLowerCase().includes(k));
            const stokOk = b.TotalStok >= minStok;
            return cocok && stokOk;
        });

        // 🔥 STEP 2: FUZZY SEARCH (kalau tidak ketemu)
        if (hasil.length === 0 && fuse) {
            const fuzzyResult = fuse.search(namaInput);

            hasil = fuzzyResult
                .filter(r => r.score <= 0.4) // 🔥 filter biar tidak ngawur
                .map(r => r.item)
                .filter(b => b.TotalStok >= minStok)
                .slice(0, 20);
        }

        // Sorting: aktif dulu, phase out terakhir
        hasil.sort((a, b) => {
            const aPhase = a.Status.toLowerCase().includes("phase");
            const bPhase = b.Status.toLowerCase().includes("phase");
            if (aPhase && !bPhase) return 1;
            if (!aPhase && bPhase) return -1;
            return 0;
        });

        const exact = hasil.find(b =>
            b.Nama.toLowerCase().trim() === inputClean &&
            !b.Status.toLowerCase().includes("phase")
        );

        return exact ? [exact] : hasil;

    } catch (error) {
        console.log('❌ Error cari index:', error.message);
        return [];
    }
}

function buildIndex() {
    if (!cachedWorkbook) {
        console.log("❌ Workbook kosong saat buildIndex");
        return;
    }
    const workbook = cachedWorkbook;

    indexBarang = [];
    indexStok = new Map();


    const sheetStok = ["FREE STOCK MTO", "FREE STOCK MTS", "STOCK 2026"];

    // 🔥 BUILD STOK SEKALI
    sheetStok.forEach(sName => {
        const sh = workbook.Sheets[sName];
        if (!sh) return;

        const data = XLSX.utils.sheet_to_json(sh, { header: 1, raw: true });

        data.forEach((row, index) => {
            if (index < 6) return;

            let nama = sName === "STOCK 2026"
                ? String(row[2] || "")
                : String(row[0] || "");

            nama = nama.replace(/\s+/g, ' ').trim();
            if (!nama || /^\d+$/.test(nama)) return;

            let qtyRaw = sName === "STOCK 2026" ? row[6] : row[1];
            let qty = typeof qtyRaw === 'number'
                ? qtyRaw
                : parseInt(String(qtyRaw || "").replace(/[^0-9]/g, '')) || 0;

            const key = normalizeNama(nama);

            if (!indexStok.has(key)) {
                indexStok.set(key, { mto: 0, mts: 0, s2026: 0 });
            }

            const current = indexStok.get(key);

            if (sName === "FREE STOCK MTO") current.mto += qty;
            if (sName === "FREE STOCK MTS") current.mts += qty;
            if (sName === "STOCK 2026") current.s2026 += qty;
        });
    });

    // 🔥 BUILD DATA BARANG
    workbook.SheetNames.forEach(sheetName => {
        if (["DISKON 2025","DISKON 2026", ...sheetStok].includes(sheetName)) return;

        const sheet = workbook.Sheets[sheetName];
        const rows = XLSX.utils.sheet_to_json(sheet, { header: 1 });

        rows.forEach(row => {
            const nama = String(row[0] || "").trim();
            if (!nama || nama.toLowerCase().includes("description")) return;

            let harga = row[1];
            if (typeof harga !== 'number') {
                harga = parseInt(String(harga || "").replace(/[^0-9]/g, '')) || 0;
            }

            const key = normalizeNama(nama);
            const stok = indexStok.get(key) || { mto: 0, mts: 0, s2026: 0 };

            indexBarang.push({
                Nama: nama,
                NamaClean: key,
                Harga: harga,
                Leadtime: String(row[2] || "-"),
                Status: String(row[3] || ""),
                StokMTO: stok.mto,
                StokMTS: stok.mts,
                Stok2026: stok.s2026,
                TotalStok: stok.mto + stok.mts + stok.s2026
            });
        });
    });

        // 🔥 INIT FUSE
    fuse = new Fuse(indexBarang, {
        keys: ['Nama'],
        threshold: 0.3,
        includeScore: true
    });

    console.log(`✅ Index siap: ${indexBarang.length} barang + Fuse aktif`);
}


