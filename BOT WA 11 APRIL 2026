                const barang = hasil[0];
                const diskonMax = getMaxDiskon(barang.Nama);
                updateMemory(barang.Nama);

                // KONDISI A: Hanya Cek Plafon (Tanpa Hitung)
                if (persen === null) {
                    const infoPlafon = diskonMax > 0 ? `🛡️ *Plafon Diskon:* ${diskonMax}%` : "🛡️ *Plafon Diskon:* Tidak diatur dalam sistem.";
                    const replyPlafon = `🔍 *INFO APPROVAL DISKON*
    ──────────────────
    📦 *Produk:* ${barang.Nama}
    ${infoPlafon}
    ──────────────────
    _Ketik "/cek diskon [angka]%" untuk hitung nett._`;
                    return await client.sendMessage(chatID, replyPlafon, { quotedMessageId: msg.id._serialized });
                }

                updateMemory(barang.Nama, persen); // Simpan keduanya ke memori

                // KONDISI B: Hitung Diskon (Input Persen Ada)
                if (diskonMax > 0 && persen > diskonMax && sessionPencarian[chatID]?.fitur !== 'konfirmasi_diskon') {
                    sessionPencarian[chatID] = { fitur: 'konfirmasi_diskon', barang, persen, asalFitur: 'diskon' };
                    return await client.sendMessage(chatID, `⚠️ *PERINGATAN DISKON*\n\nBatas maksimal diskon adalah *${diskonMax}%*.\n\nAnda memasukkan *${persen}%*. Tetap lanjut?\n*(Balas Y/T)*`);
                }

                const pot = (persen / 100) * barang.Harga;
                const nettOriginal = barang.Harga - pot;
                const nettBulat = Math.ceil(nettOriginal / 50) * 50;
                const formatRp = (n) => "Rp " + Math.round(n).toLocaleString('id-ID');
                
                // --- LOGIKA HITUNG SELISIH PLAFON ---
                const selisih = (diskonMax - persen).toFixed(1);
                const barisSelisih = diskonMax > 0 ? `📉 *Selisih Plafon:* ${selisih}%` : "";
                
                const replyHitung = `🔍 *HASIL HITUNG DISKON*
    ──────────────────
    📦 *Produk:* ${barang.Nama}
    💰 *Price List:* ${formatRp(barang.Harga)}
    🏷️ *Diskon Input:* ${persen}%
    🛡️ *Plafon Disc:* ${diskonMax}%
    ${barisSelisih}
    ──────────────────
    💵 *HARGA NETT:* ${formatRp(nettOriginal)}
    ⚖️ *PEMBULATAN:* *${formatRp(nettBulat)}*`;
                
                return await client.sendMessage(chatID, replyHitung, { quotedMessageId: msg.id._serialized });
            } else {
                return await client.sendMessage(chatID, "❌ Sebutkan nama barang atau lakukan /cek harga terlebih dahulu.");
            }
        }
    });

    async function startBot() {
    // Jalur folder session - Kita cek dua kemungkinan lokasi lock file di Windows
    const sessionPath = path.join(__dirname, '.wwebjs_auth', 'session');
    const lockFiles = [
        path.join(sessionPath, 'SingletonLock'),
        path.join(sessionPath, 'Default', 'SingletonLock')
    ];
    
    lockFiles.forEach(file => {
        if (fs.existsSync(file)) {
            try {
                console.log(`🔎 Menemukan file lock di: ${file}, membersihkan...`);
                fs.unlinkSync(file);
                console.log('✅ Berhasil menghapus file lock.');
            } catch (err) {
                console.log('⚠️ Gagal menghapus file lock otomatis. Mungkin sedang dikunci sistem.');
            }
        }
    });

    console.log('🚀 Menginisialisasi Client...');
    try {
        await client.initialize();
    } catch (err) {
        console.error('❌ Gagal inisialisasi:', err.message);
        if (err.message.includes('userDataDir')) {
            console.log('👉 SARAN: Jalankan perintah "taskkill /F /IM chrome.exe" di terminal.');
        }
    }
}

    startBot();
